---
import Base from "../../../layouts/Base.astro";
import catalog from "../../../../public/exports/catalog.json";

export function getStaticPaths() {
  return catalog.atoms.map((atom: any) => ({
    params: { type: atom.type, id: atom.id },
    props: { atom },
  }));
}

const { atom } = Astro.props;

const card = atom.model_card;
const capability = atom.capability;
const pricingTier = atom.pricing_tier;
const deprecationPolicy = atom.deprecation_policy;
const toolUseShape = atom.tool_use_shape;
const modality = atom.modality;
---
<Base title={atom.name} description={atom.description ?? `${atom.type} atom`}>
  <p><a href="/atoms/">← All atoms</a></p>
  <h1>{atom.name}</h1>
  <p style="color: var(--muted);">
    <code>{atom.type}</code> · <code>v{atom.version}</code>
  </p>

  {atom.description && <p>{atom.description}</p>}

  {card && (
    <section>
      <h2>Model details</h2>
      <dl style="display: grid; grid-template-columns: max-content 1fr; gap: 0.5rem 1rem;">
        {card.provider && (<><dt>Provider</dt><dd>{card.provider}</dd></>)}
        {card.context_window && (<><dt>Context window</dt><dd>{card.context_window.toLocaleString()} tokens</dd></>)}
        {card.modalities && card.modalities.length > 0 && (<><dt>Modalities</dt><dd>{card.modalities.join(", ")}</dd></>)}
        {card.tool_use && (<><dt>Tool use</dt><dd>{card.tool_use}</dd></>)}
        {card.vision !== undefined && (<><dt>Vision</dt><dd>{card.vision ? "yes" : "no"}</dd></>)}
      </dl>
    </section>
  )}

  {capability && (
    <section>
      <h2>Capability</h2>
      <dl style="display: grid; grid-template-columns: max-content 1fr; gap: 0.5rem 1rem;">
        {capability.name && (<><dt>Name</dt><dd>{capability.name}</dd></>)}
        {capability.description && (<><dt>Description</dt><dd>{capability.description}</dd></>)}
      </dl>
    </section>
  )}

  {pricingTier && (
    <section>
      <h2>Pricing tier</h2>
      <dl style="display: grid; grid-template-columns: max-content 1fr; gap: 0.5rem 1rem;">
        {pricingTier.tier && (<><dt>Tier</dt><dd>{pricingTier.tier}</dd></>)}
        {pricingTier.input_per_mtok && (<><dt>Input / MTok</dt><dd>${pricingTier.input_per_mtok}</dd></>)}
        {pricingTier.output_per_mtok && (<><dt>Output / MTok</dt><dd>${pricingTier.output_per_mtok}</dd></>)}
      </dl>
    </section>
  )}

  {deprecationPolicy && (
    <section>
      <h2>Deprecation policy</h2>
      <dl style="display: grid; grid-template-columns: max-content 1fr; gap: 0.5rem 1rem;">
        {deprecationPolicy.notice_period && (<><dt>Notice period</dt><dd>{deprecationPolicy.notice_period}</dd></>)}
        {deprecationPolicy.sunset_date && (<><dt>Sunset date</dt><dd>{deprecationPolicy.sunset_date}</dd></>)}
      </dl>
    </section>
  )}

  {toolUseShape && (
    <section>
      <h2>Tool-use shape</h2>
      <p style="color: var(--muted);">{JSON.stringify(toolUseShape)}</p>
    </section>
  )}

  {modality && (
    <section>
      <h2>Modality</h2>
      <p>{modality.name ?? JSON.stringify(modality)}</p>
    </section>
  )}

  {atom.tags && atom.tags.length > 0 && (
    <p>
      Tags: {atom.tags.map((tag: string) => (
        <span style="display: inline-block; font-size: 0.875rem; background: #f4ece4; padding: 0.125rem 0.5rem; border-radius: 0.25rem; margin-right: 0.25rem;">{tag}</span>
      ))}
    </p>
  )}

  <h2>Raw atom</h2>
  <p>
    <a href={`/atoms/${atom.type}/${atom.id}.json`}>/atoms/{atom.type}/{atom.id}.json</a>
    · <a href="/schemas/atom-v1.json">schema</a>
  </p>
</Base>
